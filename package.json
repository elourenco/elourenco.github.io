  "type": "module",
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "i18next": "25.10.10",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-http-backend": "3.0.6",
